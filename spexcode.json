{
  "lint": {
    "governedRoots": [
      "backend/cmd",
      "backend/internal",
      "backend/pkg",
      "frontend/src"
    ],
    "sourceExtensions": ["go", "ts", "tsx"],
    "identifierExtensions": ["go", "ts", "tsx", "json", "md"]
  },
  "dashboard": {
    "title": "Gist specs",
    "icon": "lucide:rss"
  },
  "sessions": {
    "launchers": {
      "claude": { "harness": "claude", "cmd": "claude --dangerously-skip-permissions" },
      "codex": { "harness": "codex", "cmd": "codex --yolo" }
    },
    "defaultLauncher": "codex"
  }
}
